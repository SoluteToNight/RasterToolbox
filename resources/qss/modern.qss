/* RasterToolbox dark theme: slate workspace */

/* ── Window & Root ── */

QMainWindow#mainWindow {
    background: #0f172a;
}

QWidget {
    color: #e2e8f0;
    font-family: "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    font-size: 10pt;
    selection-background-color: #1e3a5f;
    selection-color: #f8fafc;
}

/* ── Menu System ── */

QMenuBar {
    background: #1e293b;
    border-bottom: 1px solid #334155;
    color: #94a3b8;
    padding: 4px 8px;
}

QMenuBar::item {
    background: transparent;
    border-radius: 6px;
    padding: 6px 10px;
}

QMenuBar::item:selected {
    background: #1e3a5f;
    color: #e2e8f0;
}

QMenu {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 10px;
    color: #e2e8f0;
    padding: 6px;
}

QMenu::item {
    border-radius: 6px;
    padding: 7px 24px;
}

QMenu::item:selected {
    background: #1e3a5f;
    color: #e2e8f0;
}

QToolTip {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 6px;
    color: #e2e8f0;
    padding: 6px 8px;
}

/* ── Splitter ── */

QSplitter#mainSplitter {
    background: #0f172a;
}

QWidget#mainRoot {
    background: #0f172a;
}

QSplitter#mainSplitter::handle {
    background: #162234;
    border-left: 1px solid #334155;
    border-right: 1px solid #1a2332;
    margin: 16px 3px;
    width: 6px;
}

QSplitter#mainSplitter::handle:hover {
    background: #3b82f6;
    border-color: #3b82f6;
}

/* ── Navigation Pills (replaces QTabWidget) ── */

QPushButton[pillState="active"] {
    background: #1e3a5f;
    border: 1px solid #3b82f6;
    border-radius: 6px;
    color: #60a5fa;
    font-weight: 600;
    padding: 6px 16px;
}

QPushButton[pillState="inactive"] {
    background: transparent;
    border: none;
    border-radius: 6px;
    color: #94a3b8;
    padding: 6px 16px;
}

QPushButton[pillState="inactive"]:hover {
    background: #1a2332;
    color: #e2e8f0;
}

/* ── Content Areas ── */

QScrollArea#homeContentScrollArea,
QWidget#homeContentWidget {
    background: transparent;
    border: none;
}

QFrame#appHeaderBar,
QFrame#statusSummaryBar,
QFrame#homeActionsBar {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
}

QLabel#appLogoLabel {
    background: #3b82f6;
    border-radius: 6px;
    color: #ffffff;
    font-weight: 800;
    min-height: 32px;
    min-width: 32px;
}

QLabel[surfaceRole="logo"] {
    background: #3b82f6;
    border-radius: 6px;
    color: #ffffff;
}

/* ── Semantic Labels ── */

QLabel[semanticRole="title"] {
    color: #e2e8f0;
    font-size: 14pt;
    font-weight: 700;
}

QLabel[semanticRole="sectionTitle"] {
    color: #e2e8f0;
    font-size: 11pt;
    font-weight: 600;
}

QFrame#logHeaderBar {
    background: transparent;
    border: none;
}

QLabel[semanticRole="summary"],
QLabel[semanticRole="status"] {
    background: #1a2332;
    border: 1px solid #334155;
    border-radius: 6px;
    color: #94a3b8;
    padding: 8px 10px;
}

QLabel[semanticRole="badge"] {
    background: #1e3a5f;
    border: none;
    border-radius: 4px;
    color: #7dd3fc;
    font-size: 8pt;
    font-weight: 600;
    padding: 2px 8px;
}

QLabel[semanticRole="danger"],
QLabel[semanticRole="validation"] {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(248, 113, 113, 0.30);
    border-radius: 6px;
    color: #f87171;
    font-weight: 600;
    padding: 7px 10px;
}

/* ── Surface Roles ── */

QLabel[surfaceRole="preview"] {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 8px;
    color: #94a3b8;
    padding: 12px;
}

QWidget[surfaceRole="header"] {
    background: #1e293b;
    border-bottom: 1px solid #334155;
}

QWidget[surfaceRole="statusBar"] {
    background: #1e293b;
}

/* ── Panels ── */

QWidget#sourcePanel,
QWidget#presetPanel,
QWidget#queuePanel,
QWidget#logPanel {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
}

QWidget#sourcePanel:hover,
QWidget#presetPanel:hover,
QWidget#queuePanel:hover,
QWidget#logPanel:hover {
    border-color: #64748b;
}

/* ── Buttons ── */

QPushButton {
    background: #1a2332;
    border: 1px solid #334155;
    border-radius: 6px;
    color: #e2e8f0;
    min-height: 26px;
    padding: 7px 12px;
}

QPushButton:hover {
    background: #1e3a5f;
    border-color: #64748b;
}

QPushButton:pressed {
    background: #152a48;
    border-color: #3b82f6;
}

QPushButton:disabled {
    background: #0f172a;
    border-color: #334155;
    color: #64748b;
}

QPushButton[buttonRole="primary"] {
    background: #3b82f6;
    border-color: #3b82f6;
    color: #ffffff;
    font-weight: 600;
}

QPushButton[buttonRole="primary"]:hover {
    background: #60a5fa;
    border-color: #60a5fa;
}

QPushButton[buttonRole="secondary"] {
    background: #1e293b;
    border: 1px solid #475569;
    color: #e2e8f0;
}

QPushButton[buttonRole="secondary"]:hover {
    background: #1a2332;
}

QPushButton[buttonRole="accent"] {
    background: rgba(52, 211, 153, 0.15);
    border-color: #34d399;
    color: #6ee7b7;
    font-weight: 600;
}

QPushButton[buttonRole="accent"]:hover {
    background: rgba(52, 211, 153, 0.25);
}

QPushButton[buttonRole="danger"] {
    background: rgba(239, 68, 68, 0.15);
    border-color: #f87171;
    color: #fca5a5;
    font-weight: 600;
}

QPushButton[buttonRole="danger"]:hover {
    background: rgba(239, 68, 68, 0.25);
}

QPushButton[buttonRole="ghost"] {
    background: transparent;
    border: none;
    border-radius: 6px;
    color: #94a3b8;
}

QPushButton[buttonRole="ghost"]:hover {
    background: #1a2332;
    color: #e2e8f0;
}

/* ── Input Controls ── */

QComboBox,
QLineEdit,
QSpinBox,
QPlainTextEdit,
QTextEdit,
QListWidget,
QTableWidget {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 6px;
    color: #e2e8f0;
    padding: 6px 8px;
}

QComboBox:hover,
QLineEdit:hover,
QSpinBox:hover,
QPlainTextEdit:hover,
QTextEdit:hover,
QListWidget:hover,
QTableWidget:hover {
    border-color: #64748b;
}

QComboBox:focus,
QLineEdit:focus,
QSpinBox:focus,
QPlainTextEdit:focus,
QTextEdit:focus,
QListWidget:focus,
QTableWidget:focus {
    border: 1px solid #3b82f6;
}

/* ── Code / Metadata Surfaces ── */

QPlainTextEdit[surfaceRole="codeEditor"],
QPlainTextEdit[surfaceRole="logConsole"],
QPlainTextEdit[surfaceRole="metadata"],
QTextEdit[surfaceRole="metadata"] {
    background: #1a2332;
    border-color: #334155;
    color: #e2e8f0;
    font-family: "Cascadia Mono", "JetBrains Mono", "Consolas", monospace;
}

QListWidget[surfaceRole="list"] {
    background: #1a2332;
}

QTableWidget[surfaceRole="sourceTable"],
QTableWidget[surfaceRole="metadata"],
QWidget[surfaceRole="detailPanel"] {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 8px;
}

QTableWidget[surfaceRole="metadata"] {
    alternate-background-color: #1a2332;
}

QWidget#queueLogColumn {
    background: transparent;
}

/* ── ComboBox ── */

QComboBox::drop-down {
    border: none;
    width: 24px;
}

QComboBox QAbstractItemView {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 6px;
    color: #e2e8f0;
    selection-background-color: #1e3a5f;
}

QComboBox#targetPixelSizeUnitCombo {
    min-width: 160px;
}

/* ── CheckBox ── */

QCheckBox {
    spacing: 8px;
}

QCheckBox::indicator {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 4px;
    height: 16px;
    width: 16px;
}

QCheckBox::indicator:checked {
    background: #3b82f6;
    border-color: #60a5fa;
}

/* ── Table Widget ── */

QHeaderView::section {
    background: #1a2332;
    border: none;
    border-bottom: 1px solid #334155;
    border-right: 1px solid #334155;
    color: #94a3b8;
    font-weight: 600;
    padding: 8px 10px;
}

QTableWidget {
    alternate-background-color: #1a2332;
    gridline-color: transparent;
    selection-background-color: #1e3a5f;
    selection-color: #e2e8f0;
}

QTableWidget::item {
    border-bottom: 1px solid #0f172a;
    padding: 6px;
}

QTableWidget::item:selected {
    background: #1e3a5f;
    color: #e2e8f0;
}

/* ── List Widget ── */

QListWidget::item {
    border-radius: 6px;
    margin: 2px;
    padding: 7px 8px;
}

QListWidget::item:selected {
    background: #1e3a5f;
    color: #e2e8f0;
}

/* ── Status Bar ── */

QLabel[semanticRole="statusMetric"] {
    color: #e2e8f0;
    font-size: 9pt;
    font-weight: 600;
    padding: 2px 6px;
}

QLabel[semanticRole="statusInfo"] {
    color: #94a3b8;
    font-size: 9pt;
}

QLabel[surfaceRole="readyIndicator"] {
    background: #10b981;
    border-radius: 4px;
}

/* ── ScrollBar ── */

QScrollBar:vertical,
QScrollBar:horizontal {
    background: transparent;
    border: none;
    margin: 3px;
}

QScrollBar::handle:vertical,
QScrollBar::handle:horizontal {
    background: #475569;
    border-radius: 7px;
    min-height: 28px;
    min-width: 28px;
}

QScrollBar::handle:vertical:hover,
QScrollBar::handle:horizontal:hover {
    background: #64748b;
}

QScrollBar::add-line,
QScrollBar::sub-line {
    border: none;
    height: 0px;
    width: 0px;
}
